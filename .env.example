# =============================================================================
# WOW AI — Autonomous Multi-Agent Orchestration Platform
# Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
# =============================================================================

# --- Free API Keys (Required) ---

# Google Gemini API (PRIMARY — Free tier: 15 req/min, 1M tokens/day)
# Get yours at: https://aistudio.google.com
# NOTE: Gemini is the primary model for master-manager because its system prompt
# is ~28K tokens, which exceeds Groq's free tier TPM limit (12K).
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API (FALLBACK — Free tier: 12K TPM, ~30 req/min)
# Get yours at: https://console.groq.com
# NOTE: Groq works well for sub-agents (architect, coder, etc.) with smaller prompts,
# but CANNOT handle the master-manager's 28K token system prompt.
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Paid API Keys (Optional — Last Resort Fallback) ---

# OpenAI API (LAST RESORT — Only used when ALL free providers fail)
# Get yours at: https://platform.openai.com/api-keys
# Budget: $10 credit. Uses cheapest models: gpt-4.1-nano ($0.10/1M input, $0.40/1M output)
# and gpt-4.1-mini ($0.40/1M input, $1.60/1M output).
# Strategy: Single key shared across all agents. OpenAI is the absolute last fallback
# after Gemini (free) → Groq (free) → Ollama (local free) all fail.
OPENAI_API_KEY=sk-your_openai_api_key_here

# GitHub Personal Access Token (5000 req/hour)
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# --- Telegram Bot (Required for communication) ---

# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram user ID (for DM pairing)
TELEGRAM_ADMIN_ID=your_telegram_user_id_here

# --- WhatsApp (Optional secondary channel) ---

# WhatsApp uses QR code pairing via OpenClaw, no API key needed
WHATSAPP_ENABLED=false

# --- Ollama Configuration (Local inference) ---

# Ollama host address (default: localhost)
OLLAMA_HOST=0.0.0.0
OLLAMA_PORT=11434
# OpenClaw needs this to discover Ollama models (any value works — Ollama doesn't use real auth)
OLLAMA_API_KEY=ollama
# Models to use (must be pulled first via scripts/install-models.sh)
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b
OLLAMA_REASONING_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- PostgreSQL Configuration ---

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wow_ai
POSTGRES_USER=wow_ai_admin
POSTGRES_PASSWORD=change_this_to_a_strong_password
# Connection string (auto-constructed)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis Configuration ---

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# --- Kubernetes Configuration ---

# Use K3s for local development
K8S_NAMESPACE=wow-ai-agents
K8S_CONTEXT=default
# GPU time-slicing replicas (if GPU available)
GPU_REPLICAS=4

# --- OpenClaw Configuration ---

OPENCLAW_GATEWAY_PORT=3000
OPENCLAW_GATEWAY_TOKEN=generate_a_secure_random_token_here
# Max concurrent sub-agents
OPENCLAW_MAX_CONCURRENT_AGENTS=5
# Max spawn depth (agents creating agents)
OPENCLAW_MAX_SPAWN_DEPTH=3
# Agent timeout (seconds)
OPENCLAW_AGENT_TIMEOUT=3600
# Ollama context window: OpenClaw defaults to each model's full context (up to 131K).
# On systems with <=16GB RAM, this causes OOM. The fix is NOT an env var — instead,
# add models.providers.ollama section to ~/.openclaw/openclaw.json with contextWindow: 16384.
# See PROJECT_NOTES.md Session 4 for details.

# --- NemoClaw Configuration ---

# NemoClaw sandbox mode (enforce = production, permissive = development)
NEMOCLAW_MODE=permissive
# Policy directory
NEMOCLAW_POLICY_DIR=./nemoclaw/policies

# --- GUI Configuration ---

GUI_PORT=8080
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Logging ---

LOG_LEVEL=info
LOG_DIR=./logs
