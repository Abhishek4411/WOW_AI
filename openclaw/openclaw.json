{
  "$schema": "https://docs.openclaw.ai/schema/config.json",
  "gateway": {
    "port": 3000,
    "mode": "local",
    "auth": {
      "mode": "token"
    },
    "tools": {
      "allow": ["sessions_spawn", "sessions_send"]
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "open",
      "streaming": "partial"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-4.1-nano",
        "fallbacks": []
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 20000,
        "maxHistoryShare": 0.4,
        "model": "openai/gpt-4.1-nano",
        "identifierPolicy": "strict",
        "recentTurnsPreserve": 3,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000
        }
      },
      "heartbeat": {
        "every": "60m",
        "model": "openai/gpt-4.1-nano",
        "lightContext": true,
        "target": "none",
        "ackMaxChars": 100,
        "suppressToolErrorWarnings": true,
        "activeHours": {
          "start": "08:00",
          "end": "24:00",
          "timezone": "Asia/Kolkata"
        }
      }
    },
    "list": [
      {
        "id": "main"
      },
      {
        "id": "master-manager",
        "name": "master-manager",
        "model": "openai/gpt-4.1-mini",
        "subagents": {
          "allowAgents": ["architect", "coder", "qa", "researcher", "devops", "tool-maker"]
        }
      },
      {
        "id": "architect",
        "name": "architect",
        "model": "openai/gpt-4.1-mini"
      },
      {
        "id": "coder",
        "name": "coder",
        "model": "openai/gpt-4.1-mini"
      },
      {
        "id": "devops",
        "name": "devops",
        "model": "openai/gpt-4.1-mini"
      },
      {
        "id": "qa",
        "name": "qa",
        "model": "openai/gpt-4.1-mini"
      },
      {
        "id": "researcher",
        "name": "researcher",
        "model": "openai/gpt-4.1-mini"
      },
      {
        "id": "tool-maker",
        "name": "tool-maker",
        "model": "openai/gpt-4.1-mini"
      }
    ]
  },
  "acp": {
    "enabled": true,
    "dispatch": {
      "enabled": true
    },
    "backend": "acpx",
    "defaultAgent": "coder",
    "allowedAgents": ["architect", "coder", "qa", "researcher", "devops", "tool-maker"],
    "maxConcurrentSessions": 8
  },
  "plugins": {
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "command": "node",
          "strictWindowsCmdWrapper": false,
          "permissionMode": "approve-all",
          "timeoutSeconds": 300,
          "mcpServers": {
            "acpx_auth": {
              "command": "node",
              "env": {
                "OPENAI_API_KEY": "<your-openai-api-key>",
                "OLLAMA_API_KEY": "ollama"
              }
            },
            "brave-search": {
              "command": "npx",
              "args": ["-y", "@modelcontextprotocol/server-brave-search"],
              "env": {
                "BRAVE_API_KEY": "<get-free-key-at-brave.com/search/api>"
              },
              "_note": "Free tier: 2000 req/month. Replaces Gemini for web_search."
            },
            "fetch": {
              "command": "npx",
              "args": ["-y", "@modelcontextprotocol/server-fetch"],
              "_note": "No API key. Full-page content extraction for research agents."
            },
            "postgres": {
              "command": "npx",
              "args": [
                "-y", "@modelcontextprotocol/server-postgres",
                "postgresql://wow_ai_admin:wow_ai_password@localhost:5432/wow_ai"
              ],
              "_note": "Direct DB access. Agents can query/update WOW AI database."
            }
          }
        }
      }
    }
  },
  "models": {
    "providers": {
      "openai": {
        "baseUrl": "http://localhost:8001/v1",
        "api": "openai-completions",
        "_note": "Traccia proxy intercepts all calls here. Proxy forwards to api.openai.com. To disable: change baseUrl back to https://api.openai.com/v1",
        "models": [
          { "id": "gpt-4.1",      "name": "GPT-4.1",      "contextWindow": 1047576, "maxTokens": 32768 },
          { "id": "gpt-4.1-mini", "name": "GPT-4.1 Mini", "contextWindow": 1047576, "maxTokens": 32768 },
          { "id": "gpt-4.1-nano", "name": "GPT-4.1 Nano", "contextWindow": 1047576, "maxTokens": 32768 }
        ]
      }
    }
  },
  "bindings": [
    {
      "type": "route",
      "agentId": "master-manager",
      "match": {
        "channel": "telegram"
      }
    }
  ]
}
