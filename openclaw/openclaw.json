{
  "$schema": "https://docs.openclaw.ai/schema/config.json",
  "gateway": {
    "port": 3000,
    "mode": "local",
    "auth": {
      "mode": "token"
    },
    "tools": {
      "allow": ["sessions_spawn", "sessions_send"]
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "open",
      "streaming": "partial"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-4.1-nano",
        "fallbacks": [
          "google/gemini-2.5-flash",
          "groq/llama-3.3-70b-versatile"
        ]
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 20000,
        "maxHistoryShare": 0.4,
        "model": "openai/gpt-4.1-nano",
        "identifierPolicy": "strict",
        "recentTurnsPreserve": 3,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000
        }
      },
      "heartbeat": {
        "every": "60m",
        "model": "openai/gpt-4.1-nano",
        "lightContext": true,
        "target": "none",
        "ackMaxChars": 100,
        "suppressToolErrorWarnings": true,
        "activeHours": {
          "start": "08:00",
          "end": "24:00",
          "timezone": "Asia/Kolkata"
        }
      }
    },
    "list": [
      {
        "id": "main"
      },
      {
        "id": "master-manager",
        "name": "master-manager",
        "model": "openai/gpt-4.1-mini",
        "subagents": {
          "allowAgents": ["architect", "coder", "qa", "researcher", "devops", "tool-maker"]
        }
      },
      {
        "id": "architect",
        "name": "architect",
        "model": "openai/gpt-4.1-mini"
      },
      {
        "id": "coder",
        "name": "coder",
        "model": "openai/gpt-4.1-mini"
      },
      {
        "id": "devops",
        "name": "devops",
        "model": "openai/gpt-4.1-mini"
      },
      {
        "id": "qa",
        "name": "qa",
        "model": "openai/gpt-4.1-mini"
      },
      {
        "id": "researcher",
        "name": "researcher",
        "model": "openai/gpt-4.1-mini"
      },
      {
        "id": "tool-maker",
        "name": "tool-maker",
        "model": "openai/gpt-4.1-mini"
      }
    ]
  },
  "acp": {
    "enabled": true,
    "dispatch": {
      "enabled": true
    },
    "backend": "acpx",
    "defaultAgent": "coder",
    "allowedAgents": ["architect", "coder", "qa", "researcher", "devops", "tool-maker"],
    "maxConcurrentSessions": 8
  },
  "plugins": {
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "command": "node",
          "strictWindowsCmdWrapper": false,
          "permissionMode": "approve-all",
          "timeoutSeconds": 300
        }
      }
    }
  },
  "bindings": [
    {
      "type": "route",
      "agentId": "master-manager",
      "match": {
        "channel": "telegram"
      }
    }
  ]
}
